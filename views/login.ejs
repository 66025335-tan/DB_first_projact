<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <title>ยืนยันตัวตน</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light d-flex align-items-center justify-content-center vh-100">

    <div class="card shadow p-4" style="width: 100%; max-width: 400px;">
        <h3 class="text-center mb-4">ยืนยันตัวตน</h3>

        <form action="/login" method="POST">
            
            <div class="mb-3">
                <label class="form-label">ชื่อผู้ใช้</label>
                <input type="text" name="username" class="form-control" placeholder="กรอกชื่อผู้ใช้" required>
            </div>

            <div>
            <input type="password" name="password" class="form-control" placeholder="กรอกรหัสผ่าน" required>
            </div>
            
            <div class="mb-3">
                <label class="form-label"></label>
                <% if (locals.error) { %>
                    <span class="text-danger"><%= error %></span>
                <% } %>
                </table>
            </div>

            <div class="d-grid">
                <button type="submit" class="btn btn-primary">
                    เข้าสู่ระบบ
                </button>
            </div>

        </form>
    </div>

    <!-- Bootstrap 5 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>